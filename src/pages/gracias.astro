---
/**
 * /gracias/ · Thank You page · v0.9.6
 *
 * Destino del redirect de Calendly tras agendar (Confirmation Page →
 * "Redirect to an external site" → https://draelikaluque.com/gracias/ con
 * "Pass event details" activado). Si llegan invitee_full_name y
 * event_start_time por query, el saludo y la fecha se personalizan; si no,
 * la página funciona igual con textos genéricos.
 *
 * Empuja el evento `agendamiento_confirmado` al dataLayer: es la conversión
 * dura para GA4 / Google Ads / Meta.
 *
 * ⚠️ Página fuera del sitemap conceptual: no enlazarla desde menús y añadir
 * noindex cuando integremos Base.astro (nota en docs/integracion-v0.9.6.md).
 */
import Base from '../layouts/Base.astro';
import { REGISTROS } from '../config-registros';
---

<Base
  title="¡Gracias! Tu valoración quedó agendada · Dra. Elika Luque"
  description="Recibimos tu solicitud de valoración. Revisa tu correo para ver la confirmación con fecha y hora."
  variant="landing"
  noindex
>
  <main class="gr-main">
    <!-- ── 1 · Confirmación ─────────────────────────────────────────── -->
    <section class="gr-hero marca-el">
      <div class="gr-wrap">
        <div class="gr-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </div>
        <p class="gr-eyebrow">Valoración agendada</p>
        <h1 class="gr-h1">¡Gracias<span data-gr-nombre></span> por dar el primer paso!</h1>
        <p class="gr-fecha gr-oculto" data-gr-fecha></p>
        <p class="gr-lead">
          Tu cita quedó registrada. Revisa tu correo electrónico: allí está la
          confirmación con la fecha, la hora y los detalles de tu valoración de 15 minutos.
        </p>
        <ul class="gr-pasos">
          <li><span>1</span>Te llegó un correo de confirmación con tu cita.</li>
          <li><span>2</span>Nuestras asesoras te escribirán por WhatsApp para confirmar y resolver tus dudas.</li>
          <li><span>3</span>Anota las preguntas que quieras hacerle a la Dra. en tu valoración.</li>
        </ul>
      </div>
    </section>

    <!-- ── 2 · Video de la Dra. ─────────────────────────────────────── -->
    <section class="gr-video">
      <div class="gr-wrap">
        <p class="gr-eyebrow gr-eyebrow-oscuro">Mientras llega tu cita</p>
        <h2 class="gr-h2">Estás en manos expertas: conoce a la Dra.&nbsp;Elika&nbsp;Luque</h2>
        <p class="gr-sub">
          La cirujana que te acompañará en cada etapa del proceso, con un protocolo
          riguroso y un equipo completo detrás de cada paciente.
        </p>
        <div class="gr-video-marco">
          <video src={REGISTROS.videoDra} controls playsinline preload="metadata"></video>
        </div>
      </div>
    </section>

    <!-- ── 3 · Instagram ────────────────────────────────────────────── -->
    <section class="gr-ig">
      <div class="gr-wrap">
        <h2 class="gr-h2 gr-h2-claro">Sigamos en contacto</h2>
        <p class="gr-sub gr-sub-clara">
          En Instagram la Dra. comparte su día a día en cirugía, responde dudas
          frecuentes e historias reales de sus pacientes.
        </p>
        <a class="gr-btn-ig" href={REGISTROS.instagramUrl} target="_blank" rel="noopener" data-gr-ig>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.2"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1.15" fill="currentColor" stroke="none"/></svg>
          Seguir a {REGISTROS.instagramHandle}
        </a>
        <p class="gr-mini">
          <a href="/">&larr; Volver al inicio</a>
        </p>
      </div>
    </section>
  </main>
</Base>

<script>
  /* Personalización con los datos que Calendly pasa por query ("Pass event details"). */
  const q = new URLSearchParams(location.search);

  const nombreCompleto = q.get('invitee_full_name') || q.get('name') || '';
  if (nombreCompleto) {
    const span = document.querySelector('[data-gr-nombre]');
    if (span) span.textContent = `, ${nombreCompleto.trim().split(' ')[0]},`;
  }

  const inicio = q.get('event_start_time');
  if (inicio) {
    const fecha = new Date(inicio);
    if (!Number.isNaN(fecha.getTime())) {
      const texto = new Intl.DateTimeFormat('es-CO', {
        weekday: 'long', day: 'numeric', month: 'long',
        hour: 'numeric', minute: '2-digit', hour12: true,
      }).format(fecha);
      const p = document.querySelector('[data-gr-fecha]') as HTMLElement | null;
      if (p) { p.textContent = `Tu cita: ${texto}`; p.classList.remove('gr-oculto'); }
    }
  }

  (window as any).dataLayer = (window as any).dataLayer || [];
  (window as any).dataLayer.push({
    event: 'agendamiento_confirmado',
    pagina: '/gracias/',
    con_detalles: nombreCompleto ? 'si' : 'no',
  });

  document.querySelector('[data-gr-ig]')?.addEventListener('click', () => {
    (window as any).dataLayer.push({ event: 'ig_follow_click', pagina: '/gracias/' });
  });
</script>

<style>
  .gr-main { font-family: 'Open Sans', ui-sans-serif, system-ui, sans-serif; color: #1d2b38; }
  .gr-wrap { max-width: 46rem; margin: 0 auto; padding: 0 1.25rem; text-align: center; }
  .gr-oculto { display: none; }

  .gr-eyebrow {
    font-family: 'Montserrat', sans-serif; font-size: 0.74rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase; color: #f6d29a; margin: 0 0 0.6rem;
  }
  .gr-eyebrow-oscuro { color: #b98d4f; }

  /* 1 · Confirmación */
  .gr-hero {
    background: linear-gradient(175deg, #1d2b38 0%, #0e161d 100%);
    color: #ffffff; padding: 4.5rem 0 4rem;
  }
  .gr-check {
    width: 4rem; height: 4rem; margin: 0 auto 1.25rem;
    border-radius: 999px; background: #f6d29a; color: #1d2b38;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 12px 34px rgba(226, 184, 119, 0.4);
    animation: gr-pop 0.5s ease both;
  }
  .gr-check svg { width: 2rem; height: 2rem; }
  @keyframes gr-pop { from { transform: scale(0.6); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .gr-check { animation: none; } }

  .gr-h1 {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    font-size: clamp(1.8rem, 4.5vw, 2.6rem); line-height: 1.15; margin: 0 0 0.85rem;
  }
  .gr-fecha {
    display: inline-block; margin: 0 0 1rem; padding: 0.4rem 1.1rem;
    border: 1px solid rgba(246, 210, 154, 0.5); border-radius: 999px;
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.9rem; color: #f6d29a;
  }
  .gr-lead { max-width: 36rem; margin: 0 auto 2rem; font-size: 1.02rem; line-height: 1.65; color: #d6dee5; }

  .gr-pasos { list-style: none; margin: 0 auto; padding: 0; max-width: 30rem; text-align: left; }
  .gr-pasos li {
    display: flex; gap: 0.8rem; align-items: flex-start;
    padding: 0.55rem 0; font-size: 0.94rem; color: #eef2f5;
  }
  .gr-pasos li span {
    flex: none; width: 1.6rem; height: 1.6rem; border-radius: 999px;
    background: rgba(246, 210, 154, 0.16); border: 1px solid rgba(246, 210, 154, 0.55);
    color: #f6d29a; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.78rem;
    display: flex; align-items: center; justify-content: center; margin-top: 0.05rem;
  }

  /* 2 · Video */
  .gr-video { background: #f8f5ef; padding: 4rem 0 4.25rem; }
  .gr-h2 {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    font-size: clamp(1.4rem, 3.4vw, 1.9rem); line-height: 1.22; margin: 0 0 0.7rem; color: #1d2b38;
  }
  .gr-sub { max-width: 34rem; margin: 0 auto 1.8rem; font-size: 0.98rem; line-height: 1.6; color: #46586a; }
  .gr-video-marco {
    border-radius: 1.1rem; overflow: hidden; background: #0e161d;
    border: 1px solid rgba(29, 43, 56, 0.12);
    box-shadow: 0 26px 60px rgba(29, 43, 56, 0.22);
  }
  .gr-video-marco video { display: block; width: 100%; height: auto; }

  /* 3 · Instagram */
  .gr-ig { background: #1d2b38; padding: 4rem 0 4.5rem; }
  .gr-h2-claro { color: #ffffff; }
  .gr-sub-clara { color: #c9d3dc; }
  .gr-btn-ig {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.9rem 1.9rem; border-radius: 999px;
    background: #f6d29a; color: #1d2b38; text-decoration: none;
    font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.98rem;
    white-space: nowrap; box-shadow: 0 10px 28px rgba(226, 184, 119, 0.38);
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .gr-btn-ig:hover { background: #e2b877; transform: translateY(-1px); }
  .gr-btn-ig:focus-visible { outline: 3px solid #f6d29a; outline-offset: 3px; }
  .gr-btn-ig svg { width: 1.25rem; height: 1.25rem; }
  .gr-mini { margin: 1.6rem 0 0; font-size: 0.82rem; }
  .gr-mini a { color: #8fa1b1; text-decoration: underline; }
  .gr-mini a:hover { color: #f6d29a; }
</style>
