---
/**
 * L5 /reflujo/ — Nicho de alta intención (manga vs. bypass). URL conservada.
 * Fiel a mockups Landing_5 (H1–H4, PC + responsive).
 *
 * HERO DINÁMICO POR UTM (patrón L3/L4). Variantes:
 *   ?hero= reflujo | nocturno | antiacidos | decision
 *   Aquí solo cambian título/sub/foto: los checks, el CTA navy, el círculo de
 *   WhatsApp y el disclaimer son idénticos en las 4 guías.
 *
 * FIDELIDAD VISUAL (lección de L4): columna centrada, botón único navy de
 * ancho uniforme (max-w-md, sin saltos de línea), WA circular centrado.
 *
 * ⚠️ NOTA DE MOCKUP: el responsive H1 traía por error el subtítulo del balón
 *    (L4); se usa el del PC H1, coherente con reflujo.
 * ⚠️ Testimonios (Claudia, Pilar, Lina): confirmar consentimiento antes de pauta.
 * ⚠️ FAQ: respuestas borrador — validar con la Dra. (en especial la #1, que
 *    está redactada sin prometer mejoría: compliance).
 */
import Base from '../layouts/Base.astro';
import SellosCredenciales from '../components/landing/SellosCredenciales.astro';
import AgendaContacto from '../components/landing/AgendaContacto.astro';
import TimelineSeguimiento from '../components/landing/TimelineSeguimiento.astro';
import TestimoniosLanding from '../components/landing/TestimoniosLanding.astro';
import { SITE, waLink } from '../config';

const waMsg = 'Hola, tengo reflujo y quiero información sobre mi ruta (manga o bypass) con la Dra. Elika Luque.';

const heroDefault = {
  titulo: 'Reflujo y peso: definimos la mejor opción según tu caso',
  sub: 'Si vives con acidez, tos nocturna o antiácidos frecuentes, aquí te explicamos cómo evaluamos y qué sigue.',
  img: '/images/landing/hero-reflujo-peso.webp',
  alt: 'Médica sosteniendo las manos de su paciente durante la consulta',
};

const salesCon = [
  { icon: '/images/landing/icon-candidatura.png', titulo: 'Si eres candidato(a)', desc: 'a tratamiento bariátrico / metabólico (según caso)' },
  { icon: '/images/landing/icon-ruta.png', titulo: 'Ruta orientativa', desc: '(manga vs. bypass u otra opción)' },
  { icon: '/images/landing/icon-ruta-checks.png', titulo: 'Siguientes pasos claros', desc: '(estudios / valoración completa / plan)' },
];

const noche = [
  'Acidez que despierta',
  'Tos nocturna / carraspera',
  'Sensación de que «sube» comida',
  'Dormir sentado(a) o con almohada elevada',
];

/* ⚠️ Del mockup — confirmar consentimiento antes de pauta */
const testimonios = [
  { nombre: 'Claudia Sandoval', frase: 'Volví a dormir mejor.' },
  { nombre: 'Pilar Calderón', frase: 'Me dio tranquilidad entender mi ruta.' },
  { nombre: 'Lina Carreño', frase: 'Tomé una decisión con claridad.' },
];

const decision = [
  { n: 1, titulo: 'Síntomas', desc: 'cuándo aparecen y qué tanto afectan (especialmente nocturno)' },
  { n: 2, titulo: 'Estudios', desc: 'los que correspondan según tu caso' },
  { n: 3, titulo: 'Ruta + seguimiento', desc: 'opción más segura + plan de controles' },
];

const reviso = [
  'Historia clínica y antecedentes',
  'Síntomas + medicamentos / hábitos',
  'Estudios que correspondan (según caso)',
];

/* Borrador — ⚠️ validar con la Dra. */
const faqs = [
  { q: '¿El reflujo puede mejorar?', a: 'Depende del caso. En algunos pacientes el reflujo está relacionado con el peso y la anatomía; por eso la ruta se define con evaluación y estudios, buscando la opción más segura también frente al reflujo. No hacemos promesas: hacemos evaluación.' },
  { q: '¿Cómo se decide manga vs. bypass?', a: 'Con criterios clínicos: la severidad del reflujo, tu IMC, condiciones como la diabetes y tus estudios. Un reflujo frecuente o severo suele inclinar la ruta hacia bypass, pero la decisión se confirma en valoración.' },
  { q: '¿Qué incluye la prevaloración sin costo (15 min)?', a: 'Revisamos tu caso, definimos si eres candidata o candidato, aclaramos la ruta orientativa (manga, bypass u otra) y los siguientes pasos, incluidos los estudios que correspondan.' },
  { q: '¿Es virtual o presencial?', a: 'Ambas: por videollamada o presencial en Barranquilla. Lo eliges al agendar.' },
  { q: '¿Qué pasa después de la prevaloración?', a: 'Si decides avanzar, siguen los exámenes y la valoración preoperatoria. El equipo coordina las fechas contigo.' },
  { q: '¿Qué estudios pueden pedirme?', a: 'Depende de tu caso: pueden incluir endoscopia, laboratorios y valoraciones complementarias. La lista exacta se define en tu prevaloración.' },
  { q: '¿Cómo es el seguimiento de 1 año?', a: 'Controles a las 72 horas, día 6–8, día 15, día 30, mes 3, mes 6 y al año. Los dos primeros presenciales; el resto pueden ser virtuales.' },
  { q: '¿Qué pasa si vivo fuera de Colombia?', a: 'Hacemos la prevaloración virtual antes de tu viaje, coordinamos exámenes y cirugía según tus fechas, y parte del seguimiento puede ser virtual desde tu país.' },
  { q: '¿Cuánto tarda el proceso?', a: 'En promedio, alrededor de 1 mes desde la valoración hasta la cirugía, según tus exámenes y la agenda. Internacional: depende de las fechas de viaje.' },
  { q: '¿Cómo agendo / horarios?', a: 'Puedes agendar en esta página o por WhatsApp con la secretaría. Prevaloraciones: lunes, martes, jueves y viernes de 3:00 a 7:00 p. m.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<Base
  variant="landing"
  title="Reflujo y peso: ¿manga o bypass? Definimos tu ruta · Dra. Elika Luque"
  description="Si vives con acidez, tos nocturna o antiácidos frecuentes, la ruta (manga o bypass) se define con evaluación y estudios. Prevaloración sin costo de 15 minutos con la Dra. Elika Luque, Barranquilla."
  ogImage="/images/landing/hero-reflujo-peso.webp"
>
  <script is:inline type="application/ld+json" set:html={faqJsonLd} />

  <!-- 1 · HERO (variante dinámica por UTM) — columna centrada fiel al mockup -->
  <section class="bg-white">
    <div class="wrap py-8 md:py-14 grid gap-10 lg:grid-cols-2 items-center">
      <div class="text-center">
        <h1 id="hero-title" class="text-3xl md:text-[2.5rem] leading-tight text-azul">{heroDefault.titulo}</h1>
        <p id="hero-sub" class="mt-4 font-display font-semibold text-dorado-600 leading-relaxed max-w-md mx-auto">{heroDefault.sub}</p>

        <ul class="mt-6 inline-flex flex-col items-start gap-2.5 text-left" role="list">
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <img src="/images/landing/check.png" alt="" class="h-4 w-4 mt-0.5" />
            <span><strong class="font-display">Claridad:</strong> manga vs. bypass se define con evaluación</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <img src="/images/landing/check.png" alt="" class="h-4 w-4 mt-0.5" />
            <span><strong class="font-display">Ruta segura</strong> + seguimiento</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <img src="/images/landing/check.png" alt="" class="h-4 w-4 mt-0.5" />
            <span><strong class="font-display">Prevaloración</strong> sin costo (15 min) para orientarte</span>
          </li>
        </ul>

        <div class="mt-7 flex flex-col items-center gap-3.5">
          <a href={SITE.calendly} class="btn btn-navy w-full max-w-md">Agendar Prevaloración sin costo (15 min)</a>
          <a
            href={waLink(waMsg)}
            target="_blank"
            rel="noopener"
            aria-label="Escríbenos por WhatsApp"
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg hover:scale-105 transition-transform"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.5 14.98L2 22l5.16-1.5A9.9 9.9 0 1 0 12.04 2zm0 18.1a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.06.9.92-2.98-.2-.31a8.2 8.2 0 1 1 6.82 3.72zm4.5-6.13c-.25-.12-1.46-.72-1.68-.8-.23-.09-.4-.13-.56.12-.17.25-.64.8-.79.97-.14.16-.29.18-.53.06a6.7 6.7 0 0 1-3.35-2.93c-.25-.43.25-.4.72-1.34.08-.16.04-.3-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42h-.48c-.16 0-.43.06-.66.3-.22.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.13.17 1.75 2.67 4.23 3.74.6.26 1.06.41 1.42.53.6.19 1.14.16 1.57.1.48-.07 1.46-.6 1.67-1.18.2-.58.2-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
          </a>
        </div>
        <p class="mt-5 text-xs text-azul/45">
          La recomendación final se confirma tras valoración clínica<br />y estudios, según tu caso.
        </p>
      </div>
      <img
        id="hero-img"
        src={heroDefault.img}
        alt={heroDefault.alt}
        class="w-full max-w-lg justify-self-center lg:justify-self-end rounded-3xl"
        width="1000"
        height="945"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- Selección de variante (solo título + sub + foto: los checks/CTA son idénticos en las 4 guías) -->
  <script is:inline>
    (function () {
      var V = {
        reflujo: null, /* default pre-renderizado */
        nocturno: {
          t: 'Reflujo nocturno: aclara tu ruta en 15 min',
          s: 'Si el reflujo te despierta o afecta tu sueño, vale la pena evaluar con claridad.',
          i: '/images/landing/hero-reflujo-nocturno.webp',
          a: 'Médica revisando la historia clínica de pie junto a su paciente',
        },
        antiacidos: {
          t: '¿Antiácidos todos los días? Vale la pena evaluar tu caso',
          s: 'Es común vivir con antiácidos. Lo importante es definir una ruta segura según tu caso.',
          i: '/images/landing/hero-reflujo-antiacidos.webp',
          a: 'Médica mostrando información en el celular durante la consulta',
        },
        decision: {
          t: '¿Manga o bypass con reflujo? Depende de tu caso',
          s: 'No hay una respuesta única. Te mostramos cómo se toma la decisión con evaluación y estudios.',
          i: '/images/landing/hero-reflujo-decision.webp',
          a: 'Médica conversando con su paciente sobre las opciones de tratamiento',
        },
      };
      function ls(k) { try { return localStorage.getItem('el_' + k) || ''; } catch (e) { return ''; } }
      var p = new URLSearchParams(location.search);
      var v = (p.get('hero') || p.get('h') || '').toLowerCase();
      if (!(v in V)) {
        var pool = [
          p.get('utm_content'), p.get('utm_term'), p.get('utm_campaign'),
          ls('utm_content'), ls('utm_term'), ls('utm_campaign'),
        ].join(' ').toLowerCase();
        v = (pool.indexOf('nocturn') > -1 || pool.indexOf('noche') > -1 || pool.indexOf('duerm') > -1 || pool.indexOf('sueno') > -1) ? 'nocturno'
          : (pool.indexOf('antiacid') > -1 || pool.indexOf('omeprazol') > -1) ? 'antiacidos'
          : (pool.indexOf('manga') > -1 || pool.indexOf('bypass') > -1 || pool.indexOf('decision') > -1) ? 'decision'
          : 'reflujo';
      }
      var d = V[v];
      if (d) {
        document.getElementById('hero-title').textContent = d.t;
        document.getElementById('hero-sub').textContent = d.s;
        var img = document.getElementById('hero-img');
        img.src = d.i;
        img.alt = d.a;
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'hero_variant', hero_variant: v, pagina: '/reflujo/' });
    })();
  </script>

  <!-- 2 · NOTA LATAM -->
  <section class="bg-white border-t border-azul/10">
    <div class="wrap py-8">
      <p class="text-center font-display italic text-azul/80">
        Pacientes LATAM: pueden hacer la prevaloración<br class="hidden sm:block" />
        antes de viajar y coordinar fechas.
      </p>
    </div>
  </section>

  <!-- 3 · SALES CON -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="text-2xl md:text-3xl">
        En tu <span class="text-dorado-600">prevaloración</span> sin costo <span class="text-dorado-600">(15 min)</span> sales con:
      </h2>
      <div class="mt-11 grid gap-9 sm:grid-cols-3 max-w-4xl mx-auto">
        {salesCon.map((s) => (
          <div class="reveal">
            <img src={s.icon} alt="" class="h-20 w-20 mx-auto" loading="lazy" />
            <h3 class="mt-4 font-display font-semibold text-azul">{s.titulo}</h3>
            <p class="mt-1 text-sm text-azul/60">{s.desc}</p>
          </div>
        ))}
      </div>
      <a href={SITE.calendly} class="btn btn-navy mt-10">Agendar (15 min)</a>
    </div>
  </section>

  <!-- 4 · ¿TE PASA ESTO EN LA NOCHE? -->
  <section class="bg-dorado/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="text-2xl md:text-3xl text-center">¿Te pasa esto <span class="text-dorado-600">en la noche?</span></h2>
      <div class="max-w-2xl mx-auto mt-8">
        {noche.map((n) => (
          <div class="check-row"><img src="/images/landing/check.png" alt="" /> {n}</div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-azul/60 italic">*Si te identificas, vale la pena evaluar tu caso.</p>
      <div class="text-center">
        <a href={SITE.calendly} class="btn btn-navy mt-5">Agendar Prevaloración sin costo (15 min)</a>
      </div>
    </div>
  </section>

  <!-- 5 · TESTIMONIOS ⚠️ confirmar consentimiento antes de pauta -->
  <TestimoniosLanding
    titulo='Lo que más mencionan <span class="text-dorado-600">nuestros pacientes</span>'
    items={testimonios}
  />

  <!-- 6 · ANTIÁCIDOS -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="text-2xl md:text-3xl">¿Antiácidos u omeprazol <span class="text-dorado-600">casi todos los días?</span></h2>
      <p class="mt-4 text-azul/70 max-w-xl mx-auto">
        Es muy común. La clave es evaluar tu caso y definir la opción más segura para ti.
      </p>
      <a href={SITE.calendly} class="btn btn-navy mt-8">Agendar Prevaloración sin costo (15 min)</a>
    </div>
  </section>

  <!-- 7 · MANGA O BYPASS -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="text-2xl md:text-3xl text-center">
        ¿<span class="text-dorado-600">Manga o bypass</span> si tengo reflujo?
      </h2>
      <p class="mt-3 text-center text-sm text-azul/60">
        La decisión se confirma con evaluación y estudios, según tu caso.
      </p>
      <div class="mt-11 grid gap-6 sm:grid-cols-3 max-w-4xl mx-auto">
        {decision.map((d) => (
          <div class="reveal rounded-2xl bg-dorado/10 border border-dorado/20 p-6 pt-9 relative text-center">
            <span class="absolute -top-5 left-1/2 -translate-x-1/2 grid h-11 w-11 place-items-center rounded-full bg-dorado-600 font-display font-bold text-white">{d.n}</span>
            <p class="font-display font-semibold text-azul">{d.titulo}:</p>
            <p class="mt-1.5 text-sm text-azul/65 leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <a href={SITE.calendly} class="btn btn-navy mt-11">Agendar Prevaloración sin costo (15 min)</a>
      </div>
      <div class="mt-12">
        <SellosCredenciales />
      </div>
    </div>
  </section>

  <!-- 8 · QUÉ REVISO ANTES DE DECIDIR -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20">
      <h2 class="text-2xl md:text-3xl text-center">Qué reviso <span class="text-dorado-600">antes de decidir:</span></h2>
      <div class="max-w-2xl mx-auto mt-8">
        {reviso.map((r) => (
          <div class="check-row"><img src="/images/landing/check.png" alt="" /> {r}</div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm font-display italic text-dorado-600">
        Con esto definimos si eres candidato(a), resolvemos dudas y trazamos la ruta.
      </p>
    </div>
  </section>

  <!-- 9 · SEGUIMIENTO 1 AÑO -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="text-2xl md:text-3xl">
        <span class="text-dorado-600">Seguimiento incluido</span> hasta 1 año · Controles:
      </h2>
      <div class="mt-10">
        <TimelineSeguimiento nota="2 primeros presenciales; el resto pueden ser virtuales." />
      </div>
      <a href={SITE.calendly} class="btn btn-navy mt-7">Agendar (15 min)</a>
    </div>
  </section>

  <!-- 10 · QUÉ PASA DESPUÉS -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-18">
      <h2 class="text-2xl md:text-3xl text-center">¿Qué pasa <span class="text-dorado-600">después?</span></h2>
      <div class="max-w-2xl mx-auto mt-7">
        <div class="check-row"><img src="/images/landing/check.png" alt="" /> Prevaloración 15 min (virtual o presencial)</div>
        <div class="check-row"><img src="/images/landing/check.png" alt="" /> Si aplica: exámenes + valoración preoperatoria</div>
        <div class="check-row"><img src="/images/landing/check.png" alt="" /> Promedio de cirugía en ~1 mes (depende del caso y fechas si vienes del exterior)</div>
      </div>
    </div>
  </section>

  <!-- 11 · FAQ -->
  <section class="bg-dorado/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="text-2xl md:text-3xl text-center">Preguntas <span class="text-dorado-600">frecuentes</span></h2>
      <div class="max-w-3xl mx-auto mt-9">
        {faqs.map((f, i) => (
          <details class="faq-item" name="faq-reflujo">
            <summary>
              <span class="text-dorado-600 font-bold">{i + 1}.</span>
              {f.q}
            </summary>
            <p class="faq-body">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 12 · AGENDA Y CONTACTO -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-18">
      <h2 class="text-2xl md:text-3xl text-center">Agenda y <span class="text-dorado-600">contacto</span></h2>
      <div class="mt-7">
        <AgendaContacto />
      </div>
    </div>
  </section>

  <!-- 13 · CIERRE -->
  <section class="bg-marfil border-t border-azul/10">
    <div class="wrap py-14 md:py-20 text-center">
      <p class="font-display italic font-semibold text-xl md:text-2xl text-dorado-600">
        ¡Agenda tu Prevaloración sin costo (15 min)!
      </p>
      <div class="mt-7 flex flex-col items-center gap-3.5">
        <a href={SITE.calendly} class="btn btn-navy w-full max-w-md">Agendar prevaloración (15 min)</a>
        <a href={waLink(waMsg)} target="_blank" rel="noopener" aria-label="WhatsApp" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.5 14.98L2 22l5.16-1.5A9.9 9.9 0 1 0 12.04 2zm0 18.1a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.06.9.92-2.98-.2-.31a8.2 8.2 0 1 1 6.82 3.72z"/></svg>
        </a>
        <a href="/incluye-y-pagos/" class="mt-2 text-sm text-azul/60 underline hover:text-dorado-600 transition-colors">
          Qué incluye + opciones de pago
        </a>
      </div>
    </div>
  </section>
</Base>
