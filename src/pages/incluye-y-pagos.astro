---
/**
 * L6 /incluye-y-pagos/ — Precio y decisión final (caliente/retarget). URL conservada.
 * Fiel a mockups Landing_6 (H1–H4, PC + responsive). CIERRA EL SISTEMA (6/6).
 *
 * HERO DINÁMICO POR UTM: ?hero= proceso | balon | cirugia | internacional.
 * Aquí la variante también personaliza el MENSAJE del CTA verde de cotización.
 *
 * DECISIONES DEL MOCKUP (seguidas al pie de la letra — validar intención):
 *  · UN solo valor referencial: "19 millones COP / 6.000 USD" (el mínimo
 *    "todo incluido"). NO aparecen $11M balón / $24M bypass: la cotización
 *    exacta se canaliza por WhatsApp (asesoras = Capa 3 del semáforo).
 *  · Pagos "omitir, no negar": transferencia CO, transferencia Bank of
 *    America (USA) ⚠️ dato operativo nuevo, datáfono, efectivo. Cero
 *    mención de financiación. "Pagas al llegar. No cobramos anticipado" ✓.
 *  · "Reserva/abono (si aplica)" convive con "no cobramos anticipado":
 *    redacción del mockup respetada verbatim — la Dra. valida el matiz.
 * ⚠️ CTA verde usa SITE.whatsappQuiz (573218960696) — número aún por confirmar.
 * ⚠️ Acordeones y FAQ: respuestas borrador para validación de la Dra.
 */
import Base from '../layouts/Base.astro';
import SellosCredenciales from '../components/landing/SellosCredenciales.astro';
import AgendaContacto from '../components/landing/AgendaContacto.astro';
import TimelineSeguimiento from '../components/landing/TimelineSeguimiento.astro';
import BotonCotizarWA from '../components/landing/BotonCotizarWA.astro';
import { SITE } from '../config';

const heroDefault = {
  titulo: 'Antes de decidir, mira esto: qué incluye tu proceso',
  sub: 'No es solo el procedimiento. Es la experiencia, el acompañamiento y el seguimiento (según tu caso).',
  img: '/images/landing/hero-incluye-2.webp',
  alt: 'Médica revisando un documento junto a su paciente',
};

const cotizacion = [
  { icon: '/images/landing/icon-caso.png', titulo: 'Nos cuentas tu caso', desc: '(WhatsApp o prevaloración 15 min)' },
  { icon: '/images/landing/icon-confirmacion.png', titulo: 'Confirmamos candidatura y ruta', desc: '(manga / bypass / balón)' },
  { icon: '/images/landing/icon-compartimos.png', titulo: 'Te compartimos opciones claras:', desc: 'qué incluye + valor' },
];

const incluye = [
  { que: 'Cirugía + equipo quirúrgico (ayudantes)', para: 'Procedimiento seguro y completo' },
  { que: 'Anestesiólogo', para: 'Manejo anestésico y seguridad intraoperatoria' },
  { que: 'Clínica', para: 'Infraestructura y atención hospitalaria' },
  { que: 'Controles postoperatorios hasta 1 año', para: 'Acompañamiento y ajustes incluidos' },
];

const prioriza = [
  'Principal: Manga gástrica (Sleeve)',
  'Alternativa: Bypass (según caso)',
  'Balón: opción seleccionada (según candidatura)',
];

const pagoIconos = [
  { icon: '/images/landing/icon-particular.png', label: 'Particular' },
  { icon: '/images/landing/icon-pago-completo.png', label: 'Pago completo' },
  { icon: '/images/landing/icon-reserva.png', label: 'Reserva/abono (si aplica)' },
];

const pagoMedios = [
  'Pagas al llegar. No cobramos anticipado',
  'Transferencia (cuenta Colombia)',
  'Transferencia (Bank of America – USA)',
  'Datáfono (tarjeta)',
  'Efectivo',
];

/* ⚠️ Borrador — validar con la Dra. */
const confirmaValoracion = [
  { q: 'Estudios específicos (según caso)', a: 'Dependiendo de tu historia y tu ruta, pueden solicitarse laboratorios, endoscopia o valoraciones complementarias. Solo lo que tu caso necesite.' },
  { q: 'Valoración preoperatoria (según necesidad)', a: 'Antes de cirugía se completa la valoración preoperatoria correspondiente, incluida la evaluación preanestésica cuando aplica.' },
  { q: 'Ajustes de ruta (manga vs. bypass vs. balón)', a: 'Con la evaluación y tus estudios se confirma la ruta definitiva. Si algo cambia, te lo explicamos con claridad antes de decidir.' },
];

const internacional = [
  { icon: '/images/landing/icon-prevaloracion-l6.png', titulo: 'Prevaloración antes de viajar', desc: 'Virtual, desde tu país' },
  { icon: '/images/landing/icon-coordinacion.png', titulo: 'Coordinación de fechas', desc: 'Según tu disponibilidad' },
  { icon: '/images/landing/icon-seguimiento.png', titulo: 'Seguimiento por WhatsApp', desc: 'Según tu plan' },
];

/* ⚠️ Borrador — validar con la Dra. */
const faqs = [
  { q: '¿Por qué necesito valoración antes de cotizar exacto?', a: 'Porque el valor exacto depende de tu ruta (manga, bypass o balón) y de lo que tu caso necesite. Por eso damos un valor referencial claro y lo confirmamos contigo en valoración, sin sorpresas.' },
  { q: '¿Qué incluye el seguimiento de 1 año?', a: 'Controles a las 72 horas, día 6–8, día 15, día 30, mes 3, mes 6 y al año — incluidos, sin costo adicional. Los dos primeros presenciales; los demás pueden ser virtuales.' },
  { q: '¿Qué pasa si soy de otro país?', a: 'Hacemos la prevaloración virtual antes de tu viaje, coordinamos fechas según tu disponibilidad y recibes el valor claro antes de viajar. Contamos con cuenta para transferencia internacional (Bank of America, USA).' },
  { q: '¿Qué métodos de pago aceptan?', a: 'Transferencia (cuenta en Colombia), transferencia internacional (Bank of America, USA), datáfono (tarjeta) y efectivo. Pagas al llegar: no cobramos anticipado.' },
  { q: '¿El valor cambia si es manga vs. bypass?', a: 'Puede variar según el procedimiento y lo que tu caso requiera. El valor referencial incluye cirugía, clínica, ayudantes, anestesiólogo y los controles del primer año; el valor final se confirma en valoración.' },
  { q: '¿Qué pasa si la mejor ruta no es balón?', a: 'Nunca te quedas sin ruta: si el balón no es lo indicado, definimos juntos la opción más segura para tu caso (manga, bypass o manejo médico).' },
  { q: '¿Cuánto tarda el proceso?', a: 'En promedio, alrededor de 1 mes desde la valoración hasta la cirugía, según tus exámenes y la agenda. Internacional: depende de las fechas de viaje.' },
  { q: '¿Cómo agendo?', a: 'En esta página con el botón de agenda, o por WhatsApp para que la secretaría agende por ti. Prevaloraciones: lunes, martes, jueves y viernes de 3:00 a 7:00 p. m.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<Base
  variant="landing"
  title="Qué incluye + valor + opciones de pago · Cirugía bariátrica · Dra. Elika Luque"
  description="Antes de decidir, mira qué incluye tu proceso: cirugía, clínica, anestesiólogo y controles de 1 año. Valor referencial 19 millones COP / 6.000 USD (se confirma según caso). Cotiza por WhatsApp. Pagas al llegar: no cobramos anticipado."
  ogImage="/images/landing/hero-incluye-2.webp"
>
  <script is:inline type="application/ld+json" set:html={faqJsonLd} />

  <!-- 1 · HERO (variante dinámica por UTM) -->
  <section class="bg-white hero-lienzo">
    <div class="wrap py-8 md:py-14 grid gap-10 lg:grid-cols-2 items-center hero-enter">
      <div class="text-center">
        <h1 id="hero-title" class="text-3xl md:text-[2.5rem] leading-tight text-azul">{heroDefault.titulo}</h1>
        <p id="hero-sub" class="mt-4 font-display font-semibold text-dorado-600 leading-relaxed max-w-md mx-auto">{heroDefault.sub}</p>

        <ul class="mt-6 inline-flex flex-col items-start gap-2.5 text-left" role="list">
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <span class="check-svg check-svg-sm" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span><strong class="font-display">Claridad:</strong> qué incluye (sin sorpresas)</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <span class="check-svg check-svg-sm" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span><strong class="font-display">Seguimiento</strong> incluido hasta 1 año</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-azul/85">
            <span class="check-svg check-svg-sm" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span><strong class="font-display">Opciones de pago</strong> (particular)</span>
          </li>
        </ul>

        <div class="mt-7 flex flex-col items-center gap-3.5">
          <BotonCotizarWA id="hero-wa-cotizar" />
          <a href={SITE.calendly} class="btn btn-navy w-full max-w-md">Agendar Prevaloración sin costo (15 min)</a>
        </div>
        <p class="mt-5 text-xs text-azul/45">
          El plan final se confirma tras valoración<br />y estudios, según tu caso.
        </p>
      </div>
      <img
        id="hero-img"
        src={heroDefault.img}
        alt={heroDefault.alt}
        class="w-full max-w-lg justify-self-center lg:justify-self-end rounded-3xl img-premium"
        width="1000"
        height="945"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- Selección de variante: título + sub + foto + mensaje del CTA de cotización -->
  <script is:inline define:vars={{ WA_QUIZ: SITE.whatsappQuiz }}>
    (function () {
      var V = {
        proceso: null, /* default pre-renderizado */
        balon: {
          t: 'Antes de decidir balón gástrico: qué incluye + valor + pagos',
          s: 'Herramienta temporal + plan por fases + seguimiento para sostener el cambio.',
          i: '/images/landing/hero-incluye-1.webp',
          a: 'Médica mostrando información en tableta a su paciente',
          m: 'Hola, quiero cotizar el balón gástrico (qué incluye + valor + pagos) con la Dra. Elika Luque.',
        },
        cirugia: {
          t: 'Antes de decidir cirugía: qué incluye + valor + pagos',
          s: 'Seguridad, clínicas de alto nivel y seguimiento incluido hasta 1 año.',
          i: '/images/landing/hero-incluye-3.webp',
          a: 'Médica conversando con su paciente en el consultorio',
          m: 'Hola, quiero cotizar mi cirugía bariátrica (qué incluye + valor + pagos) con la Dra. Elika Luque.',
        },
        internacional: {
          t: 'Pacientes internacionales: claridad antes de viajar',
          s: 'Prevaloración (15 min) + coordinación de fechas + valor claro.',
          i: '/images/landing/hero-incluye-4.webp',
          a: 'Médica coordinando fechas con su paciente en tableta',
          m: 'Hola, soy paciente internacional y quiero cotizar antes de viajar (qué incluye + valor + fechas).',
        },
      };
      function ls(k) { try { return localStorage.getItem('el_' + k) || ''; } catch (e) { return ''; } }
      var p = new URLSearchParams(location.search);
      var v = (p.get('hero') || p.get('h') || '').toLowerCase();
      if (!(v in V)) {
        var pool = [
          p.get('utm_content'), p.get('utm_term'), p.get('utm_campaign'),
          ls('utm_content'), ls('utm_term'), ls('utm_campaign'),
        ].join(' ').toLowerCase();
        v = pool.indexOf('balon') > -1 ? 'balon'
          : (pool.indexOf('internacional') > -1 || pool.indexOf('panama') > -1 || pool.indexOf('guatemala') > -1 || pool.indexOf('viaj') > -1 || pool.indexOf('exterior') > -1) ? 'internacional'
          : (pool.indexOf('cirugia') > -1 || pool.indexOf('manga') > -1 || pool.indexOf('bypass') > -1) ? 'cirugia'
          : 'proceso';
      }
      var d = V[v];
      if (d) {
        document.getElementById('hero-title').textContent = d.t;
        document.getElementById('hero-sub').textContent = d.s;
        var img = document.getElementById('hero-img');
        img.src = d.i;
        img.alt = d.a;
        var wa = document.getElementById('hero-wa-cotizar');
        if (wa) wa.href = 'https://wa.me/' + WA_QUIZ + '?text=' + encodeURIComponent(d.m);
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'hero_variant', hero_variant: v, pagina: '/incluye-y-pagos/' });
    })();
  </script>

  <!-- 2 · COTIZACIÓN CLARA -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="titulo-linea text-2xl md:text-3xl">
        Cómo te damos una <span class="text-dorado-600">cotización clara</span> (sin sorpresas)
      </h2>
      <div class="reveal reveal-stagger mt-11 grid gap-9 sm:grid-cols-3 max-w-4xl mx-auto">
        {cotizacion.map((c) => (
          <div class="reveal">
            <img src={c.icon} alt="" class="icono-caja mx-auto" loading="lazy" />
            <h3 class="mt-4 font-display font-semibold text-azul">{c.titulo}</h3>
            <p class="mt-1 text-sm text-azul/60">{c.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 flex justify-center">
        <BotonCotizarWA />
      </div>
    </div>
  </section>

  <!-- 3 · QUÉ INCLUYE (tabla) -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">
        Qué incluye tu <span class="text-dorado-600">cirugía</span> (cuando aplica)
      </h2>
      <div class="max-w-3xl mx-auto mt-9 overflow-hidden rounded-2xl border border-azul/15">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-azul-950 text-marfil font-display">
              <th class="px-5 py-3.5 text-left font-bold text-base">Incluye</th>
              <th class="px-5 py-3.5 text-left font-bold text-base">Para qué sirve</th>
            </tr>
          </thead>
          <tbody>
            {incluye.map((i, idx) => (
              <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-marfil'}>
                <td class="px-5 py-4 font-display font-semibold text-azul align-top border-t border-azul/10">{i.que}</td>
                <td class="px-5 py-4 text-azul/70 align-top border-t border-azul/10">{i.para}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 4 · CONTROLES 1 AÑO -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="titulo-linea text-2xl md:text-3xl">Controles incluidos <span class="text-dorado-600">hasta 1 año</span></h2>
      <div class="mt-10">
        <TimelineSeguimiento nota="Los 2 primeros presenciales; los demás pueden ser virtuales." />
      </div>
      <a href={SITE.calendly} class="btn btn-navy mt-7">Agendar Prevaloración sin costo (15 min)</a>
    </div>
  </section>

  <!-- 5 · VALOR REFERENCIAL -->
  <section class="bg-white">
    <div class="wrap py-16 md:py-24 text-center">
      <h2 class="titulo-linea text-2xl md:text-3xl">
        <span class="text-dorado-600">Valor referencial</span> (se confirma según caso)
      </h2>
      <div class="precio-tarjeta reveal mt-9 max-w-2xl mx-auto">
        <p class="eyebrow text-dorado-600">Todo incluido</p>
        <p class="mt-5 font-display font-bold text-4xl md:text-5xl text-azul">
          19 millones COP <span class="text-dorado-600">/</span> 6.000 USD
        </p>
        <p class="mt-4 text-azul/75 max-w-xl mx-auto">
          Incluye: cirugía + clínica + ayudantes + anestesiólogo + controles 1 año.
        </p>
        <p class="mt-5 text-xs text-azul/50">
          El valor final se confirma en valoración, según tu caso y ruta.
        </p>
      </div>
    </div>
  </section>

  <!-- 6 · QUÉ SE PRIORIZA -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">¿Qué procedimiento <span class="text-dorado-600">se prioriza</span>?</h2>
      <div class="max-w-2xl mx-auto mt-8">
        {prioriza.map((p) => (
          <div class="check-row"><span class="check-svg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span> {p}</div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-azul/60 italic">La decisión se toma por evaluación, no por moda.</p>
      <div class="mt-12">
        <SellosCredenciales />
      </div>
    </div>
  </section>

  <!-- 7 · OPCIONES DE PAGO -->
  <section class="bg-dorado/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">Opciones <span class="text-dorado-600">de pago</span></h2>

      <div class="reveal reveal-stagger mt-11 grid gap-9 sm:grid-cols-3 max-w-3xl mx-auto text-center">
        {pagoIconos.map((p) => (
          <div class="reveal">
            <img src={p.icon} alt="" class="icono-caja mx-auto" loading="lazy" />
            <p class="mt-3.5 font-display font-semibold text-azul">{p.label}</p>
          </div>
        ))}
      </div>

      <div class="max-w-xl mx-auto mt-10">
        {pagoMedios.map((m) => (
          <div class="check-row !border-azul/15"><span class="check-svg" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span> {m}</div>
        ))}
      </div>

      <p class="mt-7 text-center text-xs text-azul/55">
        Las instrucciones exactas se confirman al agendar, según tu caso y país.
      </p>
      <p class="mt-2 text-center text-xs text-azul/55">
        Recibes confirmación por WhatsApp · Atención presencial · Recomendación final en valoración
      </p>

      <div class="mt-9 flex flex-col items-center gap-3.5">
        <BotonCotizarWA />
        <a href={SITE.calendly} class="btn btn-navy w-full max-w-md">Agendar Prevaloración sin costo (15 min)</a>
      </div>
    </div>
  </section>

  <!-- 8 · LO QUE SE CONFIRMA EN VALORACIÓN -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">
        Lo que se confirma <span class="text-dorado-600">en valoración</span>
      </h2>
      <p class="mt-2 text-center text-sm text-azul/60">(para evitar sorpresas)</p>
      <div class="max-w-3xl mx-auto mt-8">
        {confirmaValoracion.map((c) => (
          <details class="faq-item" name="confirma">
            <summary>{c.q}</summary>
            <p class="faq-body !pl-0">{c.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 9 · AGENDA Y TIEMPOS -->
  <section class="bg-marfil border-y border-azul/10">
    <div class="wrap py-14 md:py-18">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">Agenda y <span class="text-dorado-600">tiempos</span></h2>
      <div class="mt-7">
        <AgendaContacto />
      </div>
      <div class="mt-8 flex justify-center">
        <BotonCotizarWA />
      </div>
    </div>
  </section>

  <!-- 10 · INTERNACIONAL -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20 text-center">
      <h2 class="titulo-linea text-2xl md:text-3xl">
        Si vienes desde <span class="text-dorado-600">Panamá, Guatemala u otro país</span>
      </h2>
      <p class="mt-3 text-sm text-azul/60">Atención presencial en Barranquilla, Colombia.</p>
      <div class="reveal reveal-stagger mt-11 grid gap-9 sm:grid-cols-3 max-w-4xl mx-auto">
        {internacional.map((s) => (
          <div class="reveal">
            <img src={s.icon} alt="" class="icono-caja mx-auto" loading="lazy" />
            <h3 class="mt-4 font-display font-semibold text-azul">{s.titulo}</h3>
            <p class="mt-1 text-sm text-azul/60">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 11 · FAQ -->
  <section class="bg-marfil border-t border-azul/10">
    <div class="wrap py-14 md:py-20">
      <h2 class="titulo-linea text-2xl md:text-3xl text-center">Preguntas <span class="text-dorado-600">frecuentes</span></h2>
      <div class="max-w-3xl mx-auto mt-9">
        {faqs.map((f, i) => (
          <details class="faq-item" name="faq-pagos">
            <summary>
              <span class="text-dorado-600 font-bold">{i + 1}.</span>
              {f.q}
            </summary>
            <p class="faq-body">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 12 · CIERRE -->
  <section class="bg-white">
    <div class="wrap py-14 md:py-20 text-center">
      <p class="font-display italic font-semibold text-xl md:text-2xl text-dorado-600">
        Cotiza por WhatsApp o agenda tu prevaloración (15 min)
      </p>
      <div class="mt-7 flex justify-center">
        <BotonCotizarWA />
      </div>
    </div>
  </section>
</Base>
