---
/**
 * CTA fijo móvil — SOLO en landings (Base lo renderiza con variant="landing").
 * Un único botón de agenda: el WhatsApp lo cubre el botón flotante verde.
 */
import { SITE } from '../config';
---

<div
  class="sticky-cta fixed inset-x-0 bottom-0 z-40 sm:hidden bg-azul-950/95 backdrop-blur-md border-t border-marfil/10 p-3 pb-[max(0.75rem,env(safe-area-inset-bottom))]"
>
  <a href={SITE.calendly} class="btn btn-gold w-full">Agendar prevaloración (15 min)</a>
</div>
