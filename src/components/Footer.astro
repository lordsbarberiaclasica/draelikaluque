---
import { SITE, waLink } from '../config';
const year = new Date().getFullYear();
---

<footer id="contacto-footer" class="bg-azul-950 text-marfil/80">
  <div class="wrap py-14 grid gap-10 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <img src="/images/logo-el.png" alt="" width="44" height="44" class="h-11 w-11 object-contain" />
        <p class="font-display font-semibold text-marfil leading-tight">
          Dra. Elika Luque
          <span class="block text-[0.62rem] font-normal tracking-[0.24em] uppercase text-dorado/90">
            Cirugía bariátrica · Barranquilla
          </span>
        </p>
      </div>
      <p class="mt-5 text-sm leading-relaxed max-w-xs">
        Torre Médica del Mar, consultorio 311 · Clínica Portoazul.
        Barranquilla, Colombia.
      </p>
      <p class="mt-3 text-sm text-dorado/90">{SITE.horario}</p>
    </div>

    <nav class="text-sm" aria-label="Enlaces del sitio">
      <p class="eyebrow text-dorado mb-4">Sitio</p>
      <ul class="space-y-2.5">
        <li><a href="/procedimientos-bariaticos/" class="hover:text-dorado transition-colors">Procedimientos</a></li>
        <li><a href="/dra-elika-luque-2/" class="hover:text-dorado transition-colors">Conoce a tu cirujana</a></li>
        <li><a href="/soy-candidato/" class="hover:text-dorado transition-colors">¿Soy candidato?</a></li>
        <li><a href="/agendamiento-y-contacto/" class="hover:text-dorado transition-colors">Agendamiento y contacto</a></li>
        <li><a href="/#internacionales" class="hover:text-dorado transition-colors">Pacientes internacionales</a></li>
        <li><a href={SITE.calendly} class="hover:text-dorado transition-colors">Agendar valoración</a></li>
        <li><a href={waLink()} class="hover:text-dorado transition-colors">WhatsApp</a></li>
      </ul>
    </nav>

    <div class="text-sm">
      <p class="eyebrow text-dorado mb-4">Legal</p>
      <ul class="space-y-2.5">
        <!-- ⚠️ TODO: enlazar documentos legales reales antes de lanzar -->
        <li><a href="#" class="hover:text-dorado transition-colors" aria-disabled="true">Política de privacidad y Habeas Data (próximamente)</a></li>
        <li><a href="#" class="hover:text-dorado transition-colors" aria-disabled="true">Términos y condiciones (próximamente)</a></li>
      </ul>
      <div class="mt-6 flex items-center gap-4">
        <a href={SITE.instagram} aria-label="Instagram" class="hover:text-dorado transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.8" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={SITE.facebook} aria-label="Facebook" class="hover:text-dorado transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.3-1.5 1.6-1.5h1.3V4.9c-.3 0-1.1-.1-2-.1-2 0-3.4 1.2-3.4 3.5V11H8.6v3H11v7h2.5z"/></svg>
        </a>
      </div>
      <div class="mt-7">
        <img src="/images/luque-media.png" alt="Luque Media - Healthcare Marketing" width="132" height="66" class="h-14 w-auto opacity-95" loading="lazy" />
        <p class="mt-2 text-[0.68rem] tracking-wide text-marfil/50">Impulsado por Luque Media - Healthcare Marketing</p>
      </div>
      <div class="hidden">
      </div>
    </div>
  </div>

  <div class="border-t border-marfil/10">
    <div class="wrap py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-marfil/50">
      <p>© {year} Dra. Elika Luque. Todos los derechos reservados.</p>
      <p>La información de este sitio es orientativa y no reemplaza una valoración médica.</p>
    </div>
  </div>
</footer>
