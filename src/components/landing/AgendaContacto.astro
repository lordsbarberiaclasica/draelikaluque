---
/** Bloque "Agenda y contacto" (checks operativos) — horario desde config. */
import { SITE } from '../../config';
---

<div class="max-w-2xl mx-auto">
  <div class="check-row"><img src="/images/landing/check.png" alt="" /> Prevaloraciones: {SITE.horario}</div>
  <div class="check-row"><img src="/images/landing/check.png" alt="" /> WhatsApp (secretaría): {SITE.horarioWhatsapp}</div>
  <div class="check-row"><img src="/images/landing/check.png" alt="" /> Confirmación de consultas: sí</div>
  <div class="check-row"><img src="/images/landing/check.png" alt="" /> Si escribes fuera de horario: respuesta el siguiente día hábil</div>
</div>
