---
/**
 * "Agenda y contacto" v1.2.0 — de lista plana a 4 tarjetas con iconos SVG
 * animados (calendario que flota, WhatsApp con ondas, check con latido,
 * reloj con tic-tac). Horarios desde config: una sola fuente de verdad.
 */
import { SITE } from '../../config';
---

<div class="reveal reveal-stagger grid gap-5 sm:grid-cols-2 lg:grid-cols-4 max-w-5xl mx-auto">
  <div class="ti">
    <span class="ti-icono">
      <svg class="anim-flotar" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4.5" width="18" height="17" rx="3"/><path d="M8 2.5v4M16 2.5v4M3 9.5h18"/><path d="M8.5 14.5l2.3 2.3 4.7-4.6"/></svg>
    </span>
    <p class="ti-titulo">Prevaloraciones</p>
    <p class="ti-desc">{SITE.horario}</p>
  </div>

  <div class="ti">
    <span class="ti-icono anim-pulso">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.5 14.98L2 22l5.16-1.5A9.9 9.9 0 1 0 12.04 2zm0 18.1a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.06.9.92-2.98-.2-.31a8.2 8.2 0 1 1 6.82 3.72zm4.5-6.13c-.25-.12-1.46-.72-1.68-.8-.23-.09-.4-.13-.56.12-.17.25-.64.8-.79.97-.14.16-.29.18-.53.06a6.7 6.7 0 0 1-3.35-2.93c-.25-.43.25-.4.72-1.34.08-.16.04-.3-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42h-.48c-.16 0-.43.06-.66.3-.22.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.13.17 1.75 2.67 4.23 3.74.6.26 1.06.41 1.42.53.6.19 1.14.16 1.57.1.48-.07 1.46-.6 1.67-1.18.2-.58.2-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>
    </span>
    <p class="ti-titulo">WhatsApp (secretaría)</p>
    <p class="ti-desc">{SITE.horarioWhatsapp}</p>
  </div>

  <div class="ti">
    <span class="ti-icono">
      <svg class="anim-latido" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M8.2 12.4l2.5 2.5 5.1-5.2"/></svg>
    </span>
    <p class="ti-titulo">Confirmación de consultas</p>
    <p class="ti-desc">Sí: recibes confirmación de tu cita</p>
  </div>

  <div class="ti">
    <span class="ti-icono">
      <svg class="anim-tic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>
    </span>
    <p class="ti-titulo">¿Fuera de horario?</p>
    <p class="ti-desc">Respuesta el siguiente día hábil</p>
  </div>
</div>
