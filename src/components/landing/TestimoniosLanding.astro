---
/**
 * Testimonios breves con avatar de iniciales (sin fotos de stock).
 * ⚠️ Antes de encender pauta: confirmar que los nombres corresponden a
 * pacientes reales con consentimiento firmado.
 */
interface Props {
  titulo: string;
  items: { nombre: string; frase: string; foto?: string }[];
}
const { titulo, items } = Astro.props;
---

<section class="bg-dorado/15">
  <div class="wrap py-14 md:py-20">
    <h2 class="text-2xl md:text-3xl text-center" set:html={titulo} />
    <div class="mt-10 grid gap-5 sm:grid-cols-3 max-w-4xl mx-auto reveal reveal-stagger">
      {items.map((t) => (
        <figure class="card p-6 testi-card">
          <div class="flex items-center gap-3">
            {t.foto && (
              <img src={t.foto} alt="" loading="lazy" width="40" height="40"
                class="h-10 w-10 shrink-0 rounded-full object-cover ring-2 ring-dorado/60"
                onerror="if(this.nextElementSibling)this.nextElementSibling.style.display='grid';this.remove()" />
            )}
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-azul-950 font-display font-bold text-dorado text-sm" aria-hidden="true" style={t.foto ? 'display:none' : undefined}>
              {t.nombre.split(' ').map((w) => w[0]).join('')}
            </span>
            <figcaption class="font-display font-semibold text-sm text-azul">{t.nombre}</figcaption>
          </div>
          <blockquote class="mt-3.5 text-sm text-azul/70 leading-relaxed">«{t.frase}»</blockquote>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testi-card { position: relative; overflow: hidden; }
  .testi-card::before {
    content: "\201C";
    position: absolute;
    top: -0.6rem;
    right: 0.6rem;
    font-family: var(--font-display);
    font-size: 5.5rem;
    line-height: 1;
    color: var(--color-dorado-600);
    opacity: 0.16;
    pointer-events: none;
  }
</style>
