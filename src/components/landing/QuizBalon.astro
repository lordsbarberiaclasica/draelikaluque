---
/**
 * QuizBalon.astro · v0.9.7 · Mini-Quiz de Candidatura — Balón (L4)
 *
 * Implementa la spec "MiniQuiz Balon L4" (criterio clínico VALIDADO por la
 * Dra. — no modificar la lógica sin su aval):
 *
 *   4 pasos: IMC (peso+estatura) → cirugía previa → reflujo/hernia → captura
 *   (nombre + WhatsApp). El resultado se muestra DESPUÉS de la captura.
 *
 *   Rutas:  cirugía previa = Sí → D · reflujo = Sí → C · IMC > 32 → B ·
 *           IMC 25–32 → A · IMC < 25 → E.
 *           "No estoy seguro(a)" no bloquea; si cae en A, añade la nota de
 *           confirmación en valoración.
 *
 * Nunca muestra el IMC crudo ni la palabra "obesidad". Toda ruta invita a la
 * prevaloración. Registra en la pestaña "Registros Landing Balón Gástrico"
 * ANTES de mostrar el resultado y empuja quiz_balon_completado al dataLayer.
 *
 * Integración en /balon-gastrico/: dentro de la sección #candidato existente,
 * reemplazar el formulario de solo-captura por <QuizBalon />.
 */
import { REGISTROS } from '../../config-registros';
---

<div class="qb" id="quiz-balon">
  <header class="qb-cabecera">
    <p class="qb-tiempo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 2.5M9 2h6"/></svg>
      Menos de 1 minuto
    </p>
    <div class="qb-progreso" role="progressbar" aria-valuemin="1" aria-valuemax="4" aria-valuenow="1" aria-label="Progreso del test">
      <span class="qb-seg qb-seg-activo"></span><span class="qb-seg"></span><span class="qb-seg"></span><span class="qb-seg"></span>
    </div>
    <p class="qb-contador"><span data-qb-paso-num>1</span>/4</p>
  </header>

  <!-- ── Paso 1 · punto de partida ── -->
  <section class="qb-paso" data-qb-paso="1">
    <h3 class="qb-titulo">Veamos tu punto de partida</h3>
    <div class="qb-grid2">
      <div class="qb-campo">
        <label for="qb-peso">Peso (kg)</label>
        <input id="qb-peso" name="peso" type="number" inputmode="decimal" min="35" max="350" step="0.1" placeholder="Ej.: 84" required />
      </div>
      <div class="qb-campo">
        <label for="qb-estatura">Estatura (cm)</label>
        <input id="qb-estatura" name="estatura" type="number" inputmode="numeric" min="120" max="230" step="1" placeholder="Ej.: 162" required />
      </div>
    </div>
    <p class="qb-error qb-oculto" data-qb-error-1>Revisa el peso y la estatura para poder orientarte bien.</p>
    <button type="button" class="qb-btn qb-btn-gold" data-qb-sig-1>Siguiente&nbsp;&rarr;</button>
  </section>

  <!-- ── Paso 2 · cirugía previa ── -->
  <section class="qb-paso qb-oculto" data-qb-paso="2">
    <h3 class="qb-titulo">¿Te has realizado antes alguna cirugía en el estómago?</h3>
    <p class="qb-ayuda">(por ejemplo manga gástrica o plicatura)</p>
    <div class="qb-opciones" role="radiogroup" aria-label="Cirugía previa">
      <button type="button" class="qb-opcion" data-qb-cirugia="Sí">Sí</button>
      <button type="button" class="qb-opcion" data-qb-cirugia="No">No</button>
    </div>
    <button type="button" class="qb-atras" data-qb-atras="1">&larr; Atrás</button>
  </section>

  <!-- ── Paso 3 · reflujo / hernia ── -->
  <section class="qb-paso qb-oculto" data-qb-paso="3">
    <h3 class="qb-titulo">¿Te han diagnosticado reflujo gastroesofágico o hernia hiatal?</h3>
    <div class="qb-opciones" role="radiogroup" aria-label="Reflujo o hernia hiatal">
      <button type="button" class="qb-opcion" data-qb-reflujo="Sí">Sí</button>
      <button type="button" class="qb-opcion" data-qb-reflujo="No">No</button>
      <button type="button" class="qb-opcion" data-qb-reflujo="No estoy seguro(a)">No estoy seguro(a)</button>
    </div>
    <button type="button" class="qb-atras" data-qb-atras="2">&larr; Atrás</button>
  </section>

  <!-- ── Paso 4 · captura ── -->
  <section class="qb-paso qb-oculto" data-qb-paso="4">
    <h3 class="qb-titulo">Listo — dinos a dónde te enviamos tu orientación</h3>
    <form id="qb-form" novalidate>
      <div class="qb-campo">
        <label for="qb-nombre">Nombre</label>
        <input id="qb-nombre" name="nombre" type="text" autocomplete="name" required maxlength="90" placeholder="Tu nombre" />
      </div>
      <div class="qb-campo">
        <label for="qb-wa">WhatsApp</label>
        <div class="qb-wa">
          <select id="qb-indicativo" name="indicativo" aria-label="Indicativo de país">
            <option value="+57" selected>🇨🇴 +57</option>
            <option value="+1">🇺🇸 +1</option>
            <option value="+507">🇵🇦 +507</option>
            <option value="+593">🇪🇨 +593</option>
            <option value="+58">🇻🇪 +58</option>
            <option value="+52">🇲🇽 +52</option>
            <option value="+34">🇪🇸 +34</option>
            <option value="+56">🇨🇱 +56</option>
            <option value="+51">🇵🇪 +51</option>
            <option value="+other">Otro</option>
          </select>
          <input id="qb-wa" name="whatsapp" type="tel" inputmode="tel" autocomplete="tel-national" required maxlength="20" placeholder="300 123 4567" />
        </div>
      </div>

      <div class="qb-hp" aria-hidden="true">
        <label for="qb-web">Sitio web</label>
        <input id="qb-web" name="web" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <label class="qb-habeas">
        <input type="checkbox" name="habeas" required />
        <span>Autorizo el tratamiento de mis datos según la <a href="#" target="_blank" rel="noopener">Política de Privacidad</a>.</span>
      </label>

      <button type="submit" class="qb-btn qb-btn-gold" data-qb-ver>Ver mi orientación&nbsp;&rarr;</button>
    </form>
    <button type="button" class="qb-atras" data-qb-atras="3">&larr; Atrás</button>
  </section>

  <!-- ── Resultado ── -->
  <section class="qb-paso qb-oculto" data-qb-resultado>
    <div class="qb-sello" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.1 4.3 4.7.7-3.4 3.3.8 4.7-4.2-2.2-4.2 2.2.8-4.7L5.2 8l4.7-.7z"/></svg>
    </div>
    <h3 class="qb-titulo" data-qb-res-titulo></h3>
    <p class="qb-cuerpo" data-qb-res-cuerpo></p>
    <p class="qb-nota-extra qb-oculto" data-qb-res-nota>En tu valoración confirmamos lo del reflujo.</p>
    <a href="#" class="qb-btn qb-btn-gold" data-qb-cta1 data-skip-form target="_blank" rel="noopener"></a>
    <a href="#" class="qb-btn qb-btn-sec qb-oculto" data-qb-cta2 rel="noopener"></a>
    <p class="qb-disclaimer">Esta es una orientación educativa inicial, no un diagnóstico. Tu candidatura se confirma en la valoración médica.</p>
    <button type="button" class="qb-atras" data-qb-repetir>&#8634; Repetir el test</button>
  </section>
</div>

<script>
  import { REGISTROS } from '../../config-registros';
  import { tokenCaptcha } from '../../scripts/captcha-cliente';

  const raiz = document.getElementById('quiz-balon');

  if (raiz) {
    const pasos = raiz.querySelectorAll<HTMLElement>('[data-qb-paso]');
    const resultado = raiz.querySelector('[data-qb-resultado]') as HTMLElement;
    const segmentos = raiz.querySelectorAll<HTMLElement>('.qb-seg');
    const barra = raiz.querySelector('.qb-progreso') as HTMLElement;
    const contadorNum = raiz.querySelector('[data-qb-paso-num]') as HTMLElement;
    const cabecera = raiz.querySelector('.qb-cabecera') as HTMLElement;

    const estado = { peso: 0, estatura: 0, imc: 0, cirugia: '', reflujo: '', nombre: '', whatsapp: '' };
    let inicioMedido = false;

    const dl = (evento: string, extra: Record<string, string> = {}) => {
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push({ event: evento, pagina: location.pathname, ...extra });
    };

    const irAPaso = (n: number) => {
      pasos.forEach((p) => p.classList.toggle('qb-oculto', p.dataset.qbPaso !== String(n)));
      resultado.classList.add('qb-oculto');
      cabecera.classList.remove('qb-oculto');
      segmentos.forEach((s, i) => s.classList.toggle('qb-seg-activo', i < n));
      barra.setAttribute('aria-valuenow', String(n));
      contadorNum.textContent = String(n);
      raiz.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    /* Geo aproximada para el indicativo (sin APIs): zona horaria → prefijo */
    try {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
      const mapa: Record<string, string> = {
        'America/Bogota': '+57', 'America/New_York': '+1', 'America/Chicago': '+1',
        'America/Denver': '+1', 'America/Los_Angeles': '+1', 'America/Toronto': '+1',
        'America/Panama': '+507', 'America/Guayaquil': '+593', 'America/Caracas': '+58',
        'America/Mexico_City': '+52', 'Europe/Madrid': '+34', 'America/Santiago': '+56',
        'America/Lima': '+51',
      };
      const pref = mapa[tz];
      const sel = raiz.querySelector('#qb-indicativo') as HTMLSelectElement;
      if (pref && sel) sel.value = pref;
    } catch (_e) { /* +57 por defecto */ }

    /* Paso 1 → 2 */
    raiz.querySelector('[data-qb-sig-1]')?.addEventListener('click', () => {
      const peso = parseFloat((raiz.querySelector('#qb-peso') as HTMLInputElement).value.replace(',', '.'));
      const est = parseFloat((raiz.querySelector('#qb-estatura') as HTMLInputElement).value.replace(',', '.'));
      const err = raiz.querySelector('[data-qb-error-1]') as HTMLElement;
      const ok = peso >= 35 && peso <= 350 && est >= 120 && est <= 230;
      err.classList.toggle('qb-oculto', ok);
      if (!ok) return;
      estado.peso = peso;
      estado.estatura = est;
      estado.imc = Math.round((peso / Math.pow(est / 100, 2)) * 10) / 10;
      if (!inicioMedido) { dl('quiz_balon_inicio'); inicioMedido = true; }
      irAPaso(2);
    });

    /* Pasos 2 y 3: un tap por respuesta, avance automático */
    raiz.querySelectorAll<HTMLElement>('[data-qb-cirugia]').forEach((b) =>
      b.addEventListener('click', () => { estado.cirugia = b.dataset.qbCirugia || ''; marcar(b); irAPaso(3); })
    );
    raiz.querySelectorAll<HTMLElement>('[data-qb-reflujo]').forEach((b) =>
      b.addEventListener('click', () => { estado.reflujo = b.dataset.qbReflujo || ''; marcar(b); irAPaso(4); })
    );
    const marcar = (btn: HTMLElement) => {
      btn.parentElement?.querySelectorAll('.qb-opcion').forEach((o) => o.classList.remove('qb-opcion-activa'));
      btn.classList.add('qb-opcion-activa');
    };

    raiz.querySelectorAll<HTMLElement>('[data-qb-atras]').forEach((b) =>
      b.addEventListener('click', () => irAPaso(parseInt(b.dataset.qbAtras || '1', 10)))
    );

    /* Lógica de enrutamiento (criterio clínico validado — NO tocar) */
    const calcularRuta = () => {
      if (estado.cirugia === 'Sí') return 'D';
      if (estado.reflujo === 'Sí') return 'C';
      if (estado.imc > 32) return 'B';
      if (estado.imc >= 25) return 'A';
      return 'E';
    };
    const rangoImc = () => (estado.imc < 25 ? '<25' : estado.imc <= 32 ? '25-32' : '>32');

    const leerUtms = () => {
      const claves = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
      const q = new URLSearchParams(location.search);
      const out: Record<string, string> = {};
      for (const k of claves) out[k] = q.get(k) || '';
      return out;
    };

    const RUTAS: Record<string, { titulo: string; cuerpo: string; cta1: string; cta2?: { texto: string; tipo: 'wa' | 'link'; href?: string } }> = {
      A: {
        titulo: '¡Buenas noticias! Todo indica que podrías ser candidato(a) al balón',
        cuerpo: 'El balón gástrico es temporal, sin cirugía mayor y con acompañamiento completo. El siguiente paso es confirmar tu candidatura con la Dra. Elika en una prevaloración de 15 minutos, sin costo.',
        cta1: 'Agenda tu prevaloración sin costo',
        cta2: { texto: 'Prefiero escribir por WhatsApp', tipo: 'wa' },
      },
      B: {
        titulo: 'Para tu caso, hay una opción con mejores resultados que el balón',
        cuerpo: 'Según tu punto de partida, un procedimiento como la manga gástrica suele lograr resultados más completos y duraderos. La Dra. Elika lo evalúa contigo en una prevaloración de 15 minutos, sin costo.',
        cta1: 'Agenda tu prevaloración sin costo',
        cta2: { texto: 'Conocer la manga gástrica →', tipo: 'link', href: REGISTROS.urlManga },
      },
      C: {
        titulo: 'Con reflujo, tu ruta se define en valoración',
        cuerpo: 'El reflujo o la hernia hiatal cambian la recomendación: según tu caso, la mejor opción puede ser la manga o el bypass — no el balón. La Dra. Elika lo define contigo en 15 minutos, sin costo.',
        cta1: 'Agenda tu prevaloración sin costo',
        cta2: { texto: 'Leer sobre reflujo y peso →', tipo: 'link', href: REGISTROS.urlReflujo },
      },
      D: {
        titulo: 'Tu caso necesita una mirada experta',
        cuerpo: 'Después de una cirugía gástrica previa, el balón no es la ruta — pero sí existen opciones de revisión según tu caso. La Dra. Elika tiene amplia experiencia en estos casos. Evalúalo con ella sin costo.',
        cta1: 'Agenda tu prevaloración sin costo',
      },
      E: {
        titulo: 'El balón se indica en casos seleccionados',
        cuerpo: 'Según tu punto de partida, lo más indicado es evaluar opciones de manejo médico y nutricional. Agenda una valoración y define tu plan con acompañamiento profesional.',
        cta1: 'Agenda tu valoración sin costo',
      },
    };

    /* Paso 4: captura → registro → resultado */
    const form = raiz.querySelector('#qb-form') as HTMLFormElement;
    form?.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      if (!form.reportValidity()) return;

      const datos = new FormData(form);
      if ((datos.get('web') as string || '').trim() !== '') return;

      estado.nombre = (datos.get('nombre') as string || '').trim();
      const ind = (datos.get('indicativo') as string) === '+other' ? '' : (datos.get('indicativo') as string);
      estado.whatsapp = `${ind} ${(datos.get('whatsapp') as string || '').trim()}`.trim();

      const btn = raiz.querySelector('[data-qb-ver]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Preparando tu orientación…';

      const ruta = calcularRuta();
      const rango = rangoImc();
      const utms = leerUtms();
      const captcha = await tokenCaptcha('quiz_balon');

      const cuerpo = new URLSearchParams({
        hoja: REGISTROS.hojaBalon,
        nombre: estado.nombre,
        whatsapp: estado.whatsapp,
        peso: String(estado.peso),
        estatura: String(estado.estatura),
        imc: String(estado.imc),
        cirugia_previa: estado.cirugia,
        reflujo: estado.reflujo,
        ruta,
        imc_rango: rango,
        pagina: location.pathname,
        url_completa: location.href,
        referrer: document.referrer || '',
        recaptcha_token: captcha,
        ...utms,
      });

      if (REGISTROS.appsScriptUrl.startsWith('http')) {
        fetch(REGISTROS.appsScriptUrl, { method: 'POST', mode: 'no-cors', keepalive: true, body: cuerpo })
          .catch(() => { /* fire and forget */ });
      } else {
        console.warn('[QuizBalon] appsScriptUrl sin configurar: el lead NO se guardó en Sheets.');
      }

      dl('quiz_balon_completado', { ruta, imc_rango: rango });

      /* Pantalla de resultado */
      const r = RUTAS[ruta];
      (raiz.querySelector('[data-qb-res-titulo]') as HTMLElement).textContent = r.titulo;
      (raiz.querySelector('[data-qb-res-cuerpo]') as HTMLElement).textContent = r.cuerpo;
      (raiz.querySelector('[data-qb-res-nota]') as HTMLElement).classList.toggle(
        'qb-oculto', !(ruta === 'A' && estado.reflujo === 'No estoy seguro(a)')
      );

      const cta1 = raiz.querySelector('[data-qb-cta1]') as HTMLAnchorElement;
      cta1.textContent = r.cta1;
      try {
        const u = new URL(REGISTROS.calendlyFallback);
        for (const [k, v] of Object.entries(utms)) if (v) u.searchParams.set(k, v);
        u.searchParams.set('name', estado.nombre);
        u.searchParams.set('a1', estado.whatsapp);
        u.searchParams.set('a3', 'Balón gástrico (test L4)');
        cta1.href = u.toString();
      } catch (_e) { cta1.href = REGISTROS.calendlyFallback; }
      cta1.onclick = () => dl('quiz_balon_destino', { destino: 'calendly', ruta });

      const cta2 = raiz.querySelector('[data-qb-cta2]') as HTMLAnchorElement;
      if (r.cta2) {
        cta2.classList.remove('qb-oculto');
        cta2.textContent = r.cta2.texto;
        if (r.cta2.tipo === 'wa') {
          const ref = `[ref:${utms.utm_source || 'directo'}|${utms.utm_campaign || '-'}]`;
          const msg = `Hola, hice el test del balón y salí como candidato(a) probable, quiero confirmar mi valoración. Soy ${estado.nombre}. ${ref}`;
          cta2.href = `https://wa.me/${REGISTROS.whatsappAsesoras}?text=${encodeURIComponent(msg)}`;
          cta2.target = '_blank';
          cta2.onclick = () => dl('quiz_balon_destino', { destino: 'whatsapp', ruta });
        } else {
          cta2.href = r.cta2.href || '#';
          cta2.removeAttribute('target');
          cta2.onclick = () => dl('quiz_balon_destino', { destino: 'link_interno', ruta });
        }
      } else {
        cta2.classList.add('qb-oculto');
      }

      pasos.forEach((p) => p.classList.add('qb-oculto'));
      cabecera.classList.add('qb-oculto');
      resultado.classList.remove('qb-oculto');
      btn.disabled = false;
      btn.innerHTML = 'Ver mi orientación&nbsp;&rarr;';
      raiz.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    /* Repetir */
    raiz.querySelector('[data-qb-repetir]')?.addEventListener('click', () => {
      form?.reset();
      raiz.querySelectorAll('.qb-opcion').forEach((o) => o.classList.remove('qb-opcion-activa'));
      irAPaso(1);
    });
  }
</script>

<style>
  .qb {
    max-width: 34rem; margin: 0 auto;
    background: #ffffff; border-radius: 1.25rem;
    border: 1px solid rgba(29, 43, 56, 0.1); border-top: 5px solid #f6d29a;
    box-shadow: 0 20px 50px rgba(29, 43, 56, 0.12);
    padding: 1.75rem 1.4rem 2rem;
    font-family: 'Open Sans', ui-sans-serif, system-ui, sans-serif; color: #1d2b38;
  }
  @media (min-width: 640px) { .qb { padding: 2.25rem 2.5rem 2.5rem; } }

  .qb-cabecera { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.5rem; }
  .qb-tiempo {
    display: inline-flex; align-items: center; gap: 0.35rem; margin: 0;
    font-family: 'Montserrat', sans-serif; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: #b98d4f; white-space: nowrap;
  }
  .qb-tiempo svg { width: 0.95rem; height: 0.95rem; }
  .qb-progreso { display: flex; gap: 0.3rem; flex: 1; }
  .qb-seg { height: 0.35rem; flex: 1; border-radius: 999px; background: #e8e3d8; transition: background 0.3s ease; }
  .qb-seg-activo { background: #e2b877; }
  .qb-contador { margin: 0; font-family: 'Montserrat', sans-serif; font-size: 0.78rem; font-weight: 700; color: #7b8b98; }

  .qb-titulo {
    font-family: 'Montserrat', sans-serif; font-weight: 700;
    font-size: clamp(1.15rem, 3vw, 1.4rem); line-height: 1.25; margin: 0 0 0.5rem; color: #1d2b38;
  }
  .qb-ayuda { margin: -0.2rem 0 1rem; font-size: 0.88rem; color: #7b8b98; }

  .qb-grid2 { display: grid; gap: 0.9rem; grid-template-columns: 1fr 1fr; margin: 1rem 0 0.4rem; }
  .qb-campo { margin-bottom: 0.9rem; }
  .qb-campo label {
    display: block; font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem; font-weight: 600; margin-bottom: 0.3rem;
  }
  .qb-campo input, .qb-campo select {
    width: 100%; box-sizing: border-box;
    padding: 0.8rem 0.85rem; font: inherit; font-size: 1.05rem; color: #1d2b38;
    border: 1.5px solid #d8dee4; border-radius: 0.7rem; background: #fbfaf7;
  }
  .qb-campo input:focus, .qb-campo select:focus { outline: 2px solid #f6d29a; outline-offset: 1px; border-color: #e2b877; }
  .qb-wa { display: grid; grid-template-columns: 5.2rem 1fr; gap: 0.5rem; }

  .qb-opciones { display: grid; gap: 0.65rem; margin: 1.1rem 0 0.4rem; }
  .qb-opcion {
    width: 100%; min-height: 3.4rem; padding: 0.85rem 1.1rem;
    border: 1.5px solid #d8dee4; border-radius: 0.8rem; background: #fbfaf7;
    font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 1rem; color: #1d2b38;
    text-align: left; cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.1s ease;
  }
  .qb-opcion:hover { border-color: #e2b877; background: #fdf8ee; }
