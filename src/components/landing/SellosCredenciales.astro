---
/** Fila de sellos de credenciales + enlace (usada en L1, L3 y siguientes). */
const sellos = [
  { src: '/images/landing/sello-el-bosque.png', alt: 'Médico Cirujano · Universidad El Bosque' },
  { src: '/images/landing/sello-cirugia-general.png', alt: 'Especialista en Cirugía General · Universidad El Bosque' },
  { src: '/images/landing/sello-laparoscopia.png', alt: 'Formación Continua en Laparoscopia' },
  { src: '/images/landing/sello-felac.png', alt: 'Miembro Activo FELAC · Asociación Colombiana de Cirugía' },
];
---

<ul class="flex flex-wrap items-center justify-center gap-6" role="list">
  {sellos.map((s) => (
    <li><img src={s.src} alt={s.alt} class="h-16 w-16 md:h-20 md:w-20 object-contain" loading="lazy" /></li>
  ))}
</ul>
<p class="text-center mt-5">
  <a href="/dra-elika-luque-2/" class="text-sm underline text-azul/60 hover:text-dorado-600 transition-colors">Ver credenciales</a>
</p>
