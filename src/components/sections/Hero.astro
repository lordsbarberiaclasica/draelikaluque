---
import { SITE, waLink } from '../../config';

const chips = [
  'Más de 10 años de experiencia',
  'Formación en Europa · IRCAD Estrasburgo',
  '7 controles durante el primer año',
];
---

<section class="relative min-h-[92svh] flex items-end overflow-hidden bg-azul-950" aria-label="Presentación">
  <!-- Video de fondo: la Dra. en quirófano (comprimido, sin audio, con poster) -->
  <video
    class="hero-video absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/images/hero-poster.jpg"
    aria-hidden="true"
  >
    <source src="/videos/hero-banner.mp4" type="video/mp4" />
  </video>

  <!-- Poster de respaldo si el video se oculta (reduced motion) -->
  <div
    class="absolute inset-0 bg-cover bg-center -z-[1]"
    style="background-image:url('/images/hero-poster.jpg')"
    aria-hidden="true"
  >
  </div>

  <!-- Overlay de marca: azul profundo con degradado hacia el contenido -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-azul-950 via-azul-950/72 to-azul-950/35"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-y-0 left-0 w-full md:w-3/5 bg-gradient-to-r from-azul-950/80 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="wrap relative pt-36 pb-16 md:pb-24">
    <div class="max-w-2xl border-l-2 border-dorado/80 pl-6 md:pl-9">
      <p class="eyebrow text-dorado">Cirugía bariátrica · Barranquilla, Colombia</p>

      <h1 class="mt-5 text-4xl md:text-6xl text-marfil">
        Cirugía bariátrica y laparoscopia avanzada
      </h1>

      <p class="mt-6 text-base md:text-lg leading-relaxed text-marfil/85 max-w-xl">
        La Dra. Elika Luque —formada en el IRCAD de Estrasburgo y la Universidad
        Saint-Pierre de Bruselas— te acompaña con un protocolo riguroso que
        minimiza riesgos y un programa de seguimiento de un año completo.
      </p>

      <div class="mt-9 flex flex-col sm:flex-row gap-3.5">
        <a href={SITE.calendly} class="btn btn-gold">Agendar valoración</a>
<button type="button" class="btn" style="background:transparent;border:1.5px solid #f6d29a;color:#f6d29a" data-open-video-dra>Conoce a la Dra.</button>
        <a href={waLink()} target="_blank" rel="noopener" class="btn btn-ghost-light">
          Escríbenos por WhatsApp
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap gap-x-7 gap-y-2.5" role="list">
        {chips.map((chip) => (
          <li class="flex items-center gap-2 text-[0.8rem] text-marfil/75">
            <span class="h-1 w-1 rounded-full bg-dorado" aria-hidden="true"></span>
            {chip}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
