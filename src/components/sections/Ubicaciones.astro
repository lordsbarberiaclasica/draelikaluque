---
import { SITE, waLink } from '../../config';

const sedes = [
  {
    nombre: 'Torre Médica del Mar',
    detalle: 'Clínica Iberoamérica · Consultorio 311',
    direccion: 'Cl. 85 #50–37, Barranquilla, Atlántico',
    maps: 'https://www.google.com/maps/search/?api=1&query=Torre+M%C3%A9dica+del+Mar+Barranquilla',
    img: '/images/torre-medica.png',
  },
  {
    nombre: 'Clínica Portoazul',
    detalle: 'Sede quirúrgica',
    direccion: 'KM2 Vía Puerto Colombia, Barranquilla, Atlántico',
    maps: 'https://www.google.com/maps/search/?api=1&query=Cl%C3%ADnica+Portoazul+Barranquilla',
    img: '/images/quirofano.jpg',
  },
];
---

<section id="contacto" class="bg-marfil border-t border-azul/10">
  <div class="wrap py-20 md:py-28">
    <div class="max-w-xl reveal">
      <p class="eyebrow text-dorado-600">Ubicación y contacto</p>
      <h2 class="mt-4 text-3xl md:text-4xl">Te esperamos en Barranquilla</h2>
      <p class="mt-4 text-azul/70 leading-relaxed">
        Valoraciones: <strong class="text-azul">{SITE.horario}</strong>
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {sedes.map((s) => (
        <article class="reveal card overflow-hidden">
          <img src={s.img} alt={s.nombre} class="h-52 w-full object-cover" loading="lazy" />
          <div class="p-6">
            <h3 class="font-display font-semibold text-xl text-azul">{s.nombre}</h3>
            <p class="text-sm text-dorado-600 font-display font-semibold mt-0.5">{s.detalle}</p>
            <p class="mt-2 text-sm text-azul/65">{s.direccion}</p>
            <a href={s.maps} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-2 text-sm font-display font-semibold text-azul hover:text-dorado-600 transition-colors">
              Ver en Google Maps <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10 reveal grid gap-4 sm:grid-cols-3 text-sm">
      <a href={waLink()} target="_blank" rel="noopener" class="card p-5 hover:border-dorado-600/60 transition-colors">
        <p class="eyebrow !text-[0.6rem] text-dorado-600">WhatsApp</p>
        <p class="mt-2 font-display font-semibold text-azul">{SITE.phone}</p>
        <p class="mt-1 text-xs text-azul/55">Respuesta automática fuera de horario con enlace de agenda.</p>
      </a>
      <a href={`mailto:${SITE.email}`} class="card p-5 hover:border-dorado-600/60 transition-colors">
        <p class="eyebrow !text-[0.6rem] text-dorado-600">Correo</p>
        <p class="mt-2 font-display font-semibold text-azul break-all">{SITE.email}</p>
        <p class="mt-1 text-xs text-azul/55">Para historias clínicas y documentos.</p>
      </a>
      <a href={SITE.calendly} class="card p-5 hover:border-dorado-600/60 transition-colors">
        <p class="eyebrow !text-[0.6rem] text-dorado-600">Agenda en línea</p>
        <p class="mt-2 font-display font-semibold text-azul">Calendly</p>
        <p class="mt-1 text-xs text-azul/55">Elige el horario de tu valoración en un minuto.</p>
      </a>
    </div>
  </div>
</section>
